<Window x:Class="ShopOrdersWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление заказами"
        Height="400"
        Width="600"
        Closing="Window_Closing">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Создать" Width="100" Margin="0,0,10,0"
                    Command="{Binding CreateOrderCmd}"/>
            <Button Content="Редактировать" Width="100" Margin="0,0,10,0"
                    Command="{Binding EditOrderCmd}"/>
            <Button Content="Удалить" Width="100"
                    Command="{Binding DeleteOrderCmd}"/>
        </StackPanel>

        <!-- Список заказов -->
        <ListBox x:Name="OrdersList"
                 Grid.Row="1"
                 ItemsSource="{Binding Orders}"
                 Margin="0">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Product}" Margin="0,0,10,0"/>
                        <TextBlock Text="—" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Quantity}" Margin="0,0,10,0"/>
                        <TextBlock Text="шт." Margin="0,0,10,0"/>
                        <TextBlock Text="—" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Status}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </Grid>
</Window>